@using Torch2WebUI.Models.DTOs
@using Torch2WebUI.Services.ModServices
@using MudBlazor
@inject ISnackbar Snackbar

<MudDialog>
    <DialogContent>
        <MudStack Spacing="3">
            <MudTextField @bind-Value="ModListName"
                          Label="Mod List Name"
                          Placeholder="e.g., Survival Mods"
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          AutoFocus="true" />

            <MudTextField @bind-Value="ModListDescription"
                          Label="Description (Optional)"
                          Placeholder="Describe the purpose of this mod list..."
                          Variant="Variant.Outlined"
                          FullWidth="true"
                          Lines="3" />
        </MudStack>
    </DialogContent>

    <DialogActions>
        <MudButton OnClick="Cancel">Cancel</MudButton>
        <MudButton Variant="Variant.Filled" Color="Color.Primary" OnClick="Submit" Disabled="string.IsNullOrWhiteSpace(ModListName)">
            Create
        </MudButton>
    </DialogActions>
</MudDialog>

@code {
    [CascadingParameter]
    public IMudDialogInstance MudDialog { get; set; } = null!;

    [Parameter]
    public IModsService ModsService { get; set; } = null!;

    private string ModListName = string.Empty;
    private string ModListDescription = string.Empty;

    private void Cancel() => MudDialog.Cancel();

    private async Task Submit()
    {
        try
        {
            var request = new CreateModListRequest
            {
                Name = ModListName,
                Description = ModListDescription
            };

            await ModsService.CreateModListAsync(request);
            Snackbar.Add("Mod list created successfully", Severity.Success);
            MudDialog.Close(DialogResult.Ok(true));
        }
        catch (Exception ex)
        {
            Snackbar.Add($"Error creating mod list: {ex.Message}", Severity.Error);
        }
    }
}
