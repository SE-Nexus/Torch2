@page "/instances/{InstanceId}/profiles"
@using System.Reflection
@using System.ComponentModel
@using Torch2API.Models.Configs
@using Torch2API.Models.SE1
@using Torch2WebUI.Models
@using MudBlazor
@using System.Text.Json
@layout InstanceLayout

@inject InstanceManager InstanceManager
@inject IDialogService DialogService

<PageTitle>Instance Profiles</PageTitle>

@if (_instance is null)
{

    <MudProgressCircular Indeterminate />
    return;
}


<MudStack Spacing="3">

    <!-- 🔝 TOP BAR -->
    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h5">
                Active Profile: @_instance.ProfileName
            </MudText>

            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                @_instance.TargetWorld
            </MudChip>

            <MudSpacer />

            <MudTooltip Text="@_instance.InstanceID">
                <MudIcon Icon="@Icons.Material.Filled.Fingerprint"
                         Color="Color.Secondary" />
            </MudTooltip>

        </MudStack>
    </MudPaper>

    <!-- 🔀 MAIN CONTENT -->
    <MudGrid>


        <!-- 📜 LEFT: PROFILE LIST -->
        <MudItem xs="12" md="5" lg="3">
            <MudStack>
                <MudPaper Class="pa-2" Style="overflow-y: auto;">

                    <MudStack Row StretchItems="StretchItems.All">
                        <!-- New & Delete at top -->
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="CreateProfileAsync">
                            New
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Disabled="@(_selectedProfile == null)"
                                   OnClick="DeleteSelectedProfileAsync">
                            Delete
                        </MudButton>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-2" Style="overflow-y: auto;">
                    <MudList T="ProfileCfg" Dense="true">
                        @foreach (var profile in _instance.Profiles)
                        {
                            <MudListItem Clickable="true" Selected="@(profile == _selectedProfile)" OnClick="@(() => SelectProfile(profile))" Class="pa-2">

                                <MudStack Row>

                                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                        <MudAvatar Size="Size.Medium" Color="Color.Primary">
                                            @((!string.IsNullOrWhiteSpace(profile.InstanceName) ? profile.InstanceName.Substring(0, 1).ToUpper() : "?"))
                                        </MudAvatar>


                                        @if (profile.AutoStart)
                                        {
                                            <MudChip Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Auto</MudChip>
                                        }
                                    </MudStack>



                                    <MudStack Justify="Justify.FlexStart" Spacing="0">

                                        <MudStack Row StretchItems="StretchItems.Start">
                                            <MudText Typo="Typo.h6" Class="mb-0">
                                                @profile.InstanceName
                                            </MudText>

                                            <MudChip Size="Size.Small" Variant="Variant.Outlined">@($"Port: {profile.InstancePort}")</MudChip>
                                        </MudStack>



                                        <MudText Typo="Typo.body2">
                                            @profile.Description
                                        </MudText>

                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-0">
                                            @profile.TargetWorld
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudStack>


            
        </MudItem>


        @if (_selectedProfile != null)
        {
            <!-- 📄 RIGHT: PROFILE DETAILS -->
            <MudItem xs="12" md="7" lg="9">
                <MudPaper Class="pa-4" Style="min-height: 70vh;">
                    <MudTabs>
                        <MudTabPanel Text="Profile">
                            <MudStack Spacing="2">
                                <MudText Typo="Typo.h5">@_selectedProfile.InstanceName Profile Details</MudText>
                                <MudDivider />

                                <!-- existing profile fields (unchanged) -->
                                <MudTextField @bind-Value="_selectedProfile.InstanceName" Label="Name" Variant="Variant.Outlined" FullWidth />
                                <MudTextField @bind-Value="_selectedProfile.Description" Label="Description" Variant="Variant.Outlined" FullWidth />
                                <MudTextField @bind-Value="_selectedProfile.TargetWorld" Label="Target World" Variant="Variant.Outlined" FullWidth />
                                <MudNumericField T="ushort" @bind-Value="_selectedProfile.InstancePort" Label="Port" Variant="Variant.Outlined" Min="1" Max="65535" />
                                <MudNumericField T="int" @bind-Value="_selectedProfile.LogsMaxAge" Label="Logs Max Age (days)" Variant="Variant.Outlined" Min="0" />

                                <MudSwitch T="bool" @bind-Checked="_selectedProfile.AutoStart" Color="Color.Primary">Auto Start</MudSwitch>
                                <MudSwitch T="bool" @bind-Checked="_selectedProfile.CheckForUpdates" Color="Color.Primary">Check for Updates</MudSwitch>
                                <MudSwitch T="bool" @bind-Checked="_selectedProfile.AutoUpdateGame" Color="Color.Primary">Auto Update Game</MudSwitch>
                                <MudSwitch T="bool" @bind-Checked="_selectedProfile.RestartOnCrash" Color="Color.Primary">Restart on Crash</MudSwitch  >

                                <MudTextField @bind-Value="_selectedProfile.BranchName" Label="Game Branch" Variant="Variant.Outlined" />
                                <MudTextField @bind-Value="_selectedProfile.BranchPassword" Label="Branch Password" Variant="Variant.Outlined" InputType="InputType.Password" />

                                <MudDivider />

                                <MudStack Row StretchItems="StretchItems.All">
                                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="LoadProfileAsync">Load Profile</MudButton>
                                    <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="UpdateSelectedProfileAsync" Disabled="@(_selectedProfile == null)">Update</MudButton>
                                    <MudButton Color="Color.Error" Variant="Variant.Outlined" OnClick="DeleteSelectedProfileAsync">Delete</MudButton>
                                </MudStack>
                            </MudStack>
                        </MudTabPanel>

                        <MudTabPanel Text="Schema">
                            @if (_dedicatedConfig == null)
                            {
                                <MudText Color="Color.Secondary">No schema available. It may not have been requested yet.</MudText>
                            }
                            else
                            {
                                <!-- AsteroidAmount (int) -->
                                <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AsteroidAmount))">
                                    <MudNumericField T="int" Label="@nameof(_dedicatedConfig.AsteroidAmount)" @bind-Value="_dedicatedConfig.AsteroidAmount" Variant="Variant.Outlined" Min="0" />
                                </MudTooltip>
                            }
                        </MudTabPanel>
                    </MudTabs>
                </MudPaper>
            </MudItem>
        }



    </MudGrid>

</MudStack>






@code {
    [Parameter] public string InstanceId { get; set; } = default!;


    private MudForm? _form;
    private ProfileCfg? _selectedProfile;
    private string? _originalProfileName;

    private ConfigDedicatedSE1? _dedicatedConfig => _instance?.DedicatedConfig;
    private TorchInstance? _instance;

    protected override async Task OnInitializedAsync()
    {
        _instance = InstanceManager.GetInstanceByID(InstanceId);
        InstanceManager.OnChange += OnInstanceUpdated;

        _selectedProfile = _instance?.Profiles.FirstOrDefault();

        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        // request dedicated schema from the instance
        await InstanceManager.SendCommand(_instance, "Config/Profiles/dedicatedcfg");
    }

    private void OnInstanceUpdated(string updatedId)
    {
        if (updatedId != _instance.InstanceID)
            return;

        InvokeAsync(() =>
        {
            _instance = InstanceManager.GetInstanceByID(InstanceId);
            StateHasChanged();
        });
    }

    private void SelectProfile(ProfileCfg profile)
    {
        _selectedProfile = profile;
        _originalProfileName = profile.InstanceName;
        StateHasChanged();
    }

    private async Task CreateProfileAsync()
    {
        if (_instance is null)
            return;

        var options = new DialogParameters
        {
            ["Label"] = "Profile Name",
            ["Value"] = string.Empty,
            ["Title"] = "Create Profile",
            ["ConfirmText"] = "Create",
            ["CancelText"] = "Cancel"
        };

        var dialogRef = await DialogService.ShowAsync<Torch2WebUI.Components.Dialogs.InputDialog>("Create Profile", options, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialogRef.Result;
        if (result.Canceled || result.Data is null)
            return;

        if (result.Data is string name && !string.IsNullOrWhiteSpace(name))
        {
            await InstanceManager.SendCommand(_instance, "Config/Profiles/Create", new { name = name.Trim() });
            await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        }
    }

    // New: single confirm method that accepts an optional ProfileCfg.
    // Call without parameter to delete the selected profile, or pass a profile for item-level delete.
    private async Task ConfirmDeleteProfile(ProfileCfg? profile = null)
    {
        var target = profile ?? _selectedProfile;
        if (_instance is null || target is null)
            return;

        var dialogParams = new DialogParameters
        {
            ["Message"] = $"Delete profile '{target.InstanceName}'? This cannot be undone.",
            ["Args"] = target.InstanceName,
            ["ConfirmText"] = "Delete",
            ["CancelText"] = "Cancel",
            ["ShowCancel"] = true,
            ["ButtonIcon"] = Icons.Material.Filled.Delete
        };

        var dialogRef = await DialogService.ShowAsync<Torch2WebUI.Components.Dialogs.ConfirmDialog>($"Delete Profile '{target.InstanceName}'?", dialogParams);
        var result = await dialogRef.Result;

        if (!result.Canceled && result.Data is string confirmedName)
        {
            await InstanceManager.SendCommand(_instance, "Config/Profiles/Delete", new { name = confirmedName });
            if (_selectedProfile != null && string.Equals(_selectedProfile.InstanceName, confirmedName, StringComparison.OrdinalIgnoreCase))
            {
                _selectedProfile = null;
                _originalProfileName = null;
            }
            await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        }
    }

    // kept for backward compatibility with previous wiring; delegates to ConfirmDeleteProfile()
    private Task DeleteSelectedProfileAsync() => ConfirmDeleteProfile();

    private async Task UpdateSelectedProfileAsync()
    {
        if (_instance is null || _selectedProfile is null)
            return;

        // Use the original name as the existing identifier (in case the user renamed the InstanceName)
        var payload = new
        {
            name = _originalProfileName ?? _selectedProfile.InstanceName,
            newname = _selectedProfile.InstanceName,
            targetworld = _selectedProfile.TargetWorld,
            description = _selectedProfile.Description,
            port = _selectedProfile.InstancePort,
            autostart = _selectedProfile.AutoStart,
            checkupdates = _selectedProfile.CheckForUpdates,
            autoupdategame = _selectedProfile.AutoUpdateGame,
            restartoncrash = _selectedProfile.RestartOnCrash,
            branch = _selectedProfile.BranchName,
            branchpwd = _selectedProfile.BranchPassword,
            logsmaxage = _selectedProfile.LogsMaxAge
        };

        await InstanceManager.SendCommand(_instance, "Config/Profiles/Update", payload);

        // refresh list
        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
    }

    // Implemented load: tells the instance to load the selected profile.
    private async Task LoadProfileAsync()
    {
        if (_instance is null || _selectedProfile is null)
            return;

        await InstanceManager.SendCommand(_instance, "Config/Profiles/Load", new { name = _selectedProfile.InstanceName });

        // refresh list / server state after request
        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
    }

    public void Dispose()
    {
        InstanceManager.OnChange -= OnInstanceUpdated;
    }


    // Helper: get DescriptionAttribute string for a property
    private static string GetDescription(string propName)
    {
        var prop = typeof(ConfigDedicatedSE1).GetProperty(propName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
        var attr = prop?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? string.Empty;
    }

    

        
    }
}
