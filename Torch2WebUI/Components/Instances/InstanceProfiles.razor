@page "/instances/{InstanceId}/profiles"
@using System.Reflection
@using System.ComponentModel
@using System.Linq
@using Torch2API.Models.Configs
@using Torch2API.Models.SE1
@using Torch2WebUI.Models
@using MudBlazor
@using System.Text.Json
@layout InstanceLayout

@inject InstanceManager InstanceManager
@inject IDialogService DialogService

<PageTitle>Instance Profiles</PageTitle>

@if (_instance is null)
{

    <MudProgressCircular Indeterminate />
    return;
}


<MudStack Spacing="3">

    <!-- 🔝 TOP BAR -->
    <MudPaper Elevation="1" Class="pa-4">
        <MudStack Row AlignItems="AlignItems.Center" Spacing="3">
            <MudText Typo="Typo.h5">
                Active Profile: @_instance.ProfileName
            </MudText>

            <MudChip T="string" Color="Color.Primary" Variant="Variant.Outlined">
                @_instance.TargetWorld
            </MudChip>

            <MudSpacer />

            <MudTooltip Text="@_instance.InstanceID">
                <MudIcon Icon="@Icons.Material.Filled.Fingerprint"
                         Color="Color.Secondary" />
            </MudTooltip>

        </MudStack>
    </MudPaper>

    <!-- 🔀 MAIN CONTENT -->
    <MudGrid>


        <!-- 📜 LEFT: PROFILE LIST -->
        <MudItem xs="12" md="5" lg="3">
            <MudStack>
                <MudPaper Class="pa-2" Style="overflow-y: auto;">

                    <MudStack Row StretchItems="StretchItems.All">
                        <!-- New & Delete at top -->
                        <MudButton Variant="Variant.Filled"
                                   Color="Color.Primary"
                                   StartIcon="@Icons.Material.Filled.Add"
                                   OnClick="CreateProfileAsync">
                            New
                        </MudButton>

                        <MudButton Variant="Variant.Outlined"
                                   Color="Color.Error"
                                   StartIcon="@Icons.Material.Filled.Delete"
                                   Disabled="@(_selectedProfile == null)"
                                   OnClick="DeleteSelectedProfileAsync">
                            Delete
                        </MudButton>
                    </MudStack>
                </MudPaper>

                <MudPaper Class="pa-2" Style="overflow-y: auto;">
                    <MudList T="ProfileCfg" Dense="true" SelectedValue="_selectedProfile" SelectedValueChanged="OnProfileSelectedAsync">
                        @foreach (var profile in _instance.Profiles)
                        {
                            <MudListItem Value="profile" Class="pa-2">

                                <MudStack Row>

                                    <MudStack AlignItems="AlignItems.Center" Spacing="1">
                                        <MudAvatar Size="Size.Medium" Color="Color.Primary">
                                            @((!string.IsNullOrWhiteSpace(profile.InstanceName) ? profile.InstanceName.Substring(0, 1).ToUpper() : "?"))
                                        </MudAvatar>


                                        @if (profile.AutoStart)
                                        {
                                            <MudChip Size="Size.Small" Color="Color.Success" Variant="Variant.Filled">Auto</MudChip>
                                        }
                                    </MudStack>



                                    <MudStack Justify="Justify.FlexStart" Spacing="0">

                                        <MudStack Row StretchItems="StretchItems.Start">
                                            <MudText Typo="Typo.h6" Class="mb-0">
                                                @profile.InstanceName
                                            </MudText>

                                            <MudChip Size="Size.Small" Variant="Variant.Outlined">@($"Port: {profile.InstancePort}")</MudChip>
                                        </MudStack>



                                        <MudText Typo="Typo.body2">
                                            @profile.Description
                                        </MudText>

                                        <MudText Typo="Typo.caption" Color="Color.Secondary" Class="mt-0">
                                            @profile.TargetWorld
                                        </MudText>
                                    </MudStack>
                                </MudStack>
                            </MudListItem>
                        }
                    </MudList>
                </MudPaper>
            </MudStack>



        </MudItem>


        @if (_selectedProfile != null)
        {
            <!-- 📄 RIGHT: PROFILE DETAILS -->
            <MudItem xs="12" md="7" lg="9">
               
                
                <MudPaper Class="pa-4" Style="min-height: 70vh;">
                    <MudText Typo="Typo.h5">@_selectedProfile.InstanceName Profile Details</MudText>
                    <MudDivider />
                    <MudTabs>
                        <MudTabPanel Text="Torch Cfg">
                            <MudStack Spacing="2">

                                <!-- existing profile fields (unchanged) -->
                                <MudTextField @bind-Value="_selectedProfile.InstanceName" Label="Name" Variant="Variant.Outlined" FullWidth />
                                <MudTextField @bind-Value="_selectedProfile.Description" Label="Description" Variant="Variant.Outlined" FullWidth />
                                <MudTextField @bind-Value="_selectedProfile.TargetWorld" Label="Target World" Variant="Variant.Outlined" FullWidth />
                                <MudNumericField T="ushort" @bind-Value="_selectedProfile.InstancePort" Label="Port" Variant="Variant.Outlined" Min="1" Max="65535" />
                                <MudNumericField T="int" @bind-Value="_selectedProfile.LogsMaxAge" Label="Logs Max Age (days)" Variant="Variant.Outlined" Min="0" />

                                <MudSwitch T="bool" @bind-Value="_selectedProfile.AutoStart" Color="Color.Primary">Auto Start</MudSwitch>
                                <MudSwitch T="bool" @bind-Value="_selectedProfile.CheckForUpdates" Color="Color.Primary">Check for Updates</MudSwitch>
                                <MudSwitch T="bool" @bind-Value="_selectedProfile.AutoUpdateGame" Color="Color.Primary">Auto Update Game</MudSwitch>
                                <MudSwitch T="bool" @bind-Value="_selectedProfile.RestartOnCrash" Color="Color.Primary">Restart on Crash</MudSwitch>

                                <MudTextField @bind-Value="_selectedProfile.BranchName" Label="Game Branch" Variant="Variant.Outlined" />
                                <MudTextField @bind-Value="_selectedProfile.BranchPassword" Label="Branch Password" Variant="Variant.Outlined" InputType="InputType.Password" />

                                <MudDivider />

                                <MudStack Row StretchItems="StretchItems.All">
                                    <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="LoadProfileAsync">Load Profile</MudButton>
                                    <MudButton Color="Color.Secondary" Variant="Variant.Filled" OnClick="UpdateSelectedProfileAsync" Disabled="@(_selectedProfile == null)">Update</MudButton>
                                    <MudButton Color="Color.Error" Variant="Variant.Outlined" OnClick="DeleteSelectedProfileAsync">Delete</MudButton>
                                </MudStack>
                            </MudStack>
                        </MudTabPanel>

                        <MudTabPanel Text="Dedicated Cfg">
                            @if (_dedicatedConfig == null)
                            {
                                <MudText Color="Color.Secondary">No schema available. It may not have been requested yet.</MudText>
                            }
                            else
                            {
                                <MudStack Spacing="2">
                                    <!-- Administrators (List<string>) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.Administrators))">
                                        <MudTextField T="string"
                                                      Label="@nameof(_dedicatedConfig.Administrators)"
                                                      @bind-Value="AdministratorsText"
                                                      Variant="Variant.Outlined"
                                                      Lines="5"
                                                      FullWidth="true" />
                                    </MudTooltip>

                                    <!-- AsteroidAmount (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AsteroidAmount))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.AsteroidAmount)" @bind-Value="_dedicatedConfig.AsteroidAmount" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- Banned (List<ulong>) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.Banned))">
                                        <MudTextField T="string"
                                                      Label="@nameof(_dedicatedConfig.Banned)"
                                                      @bind-Value="BannedText"
                                                      Variant="Variant.Outlined"
                                                      Lines="5"
                                                      FullWidth="true" />
                                    </MudTooltip>

                                    <!-- Reserved (List<ulong>) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.Reserved))">
                                        <MudTextField T="string"
                                                      Label="@nameof(_dedicatedConfig.Reserved)"
                                                      @bind-Value="ReservedText"
                                                      Variant="Variant.Outlined"
                                                      Lines="5"
                                                      FullWidth="true" />
                                    </MudTooltip>

                                    <!-- GroupID (ulong) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.GroupID))">
                                        <MudNumericField T="ulong" Label="@nameof(_dedicatedConfig.GroupID)" @bind-Value="_dedicatedConfig.GroupID" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- IgnoreLastSession (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.IgnoreLastSession))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.IgnoreLastSession" Color="Color.Primary">@nameof(_dedicatedConfig.IgnoreLastSession)</MudSwitch>
                                    </MudTooltip>

                                    <!-- IP (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.IP))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.IP)" @bind-Value="_dedicatedConfig.IP" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- LoadWorld (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.LoadWorld))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.LoadWorld)" @bind-Value="_dedicatedConfig.LoadWorld" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- CrossPlatform (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.CrossPlatform))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.CrossPlatform" Color="Color.Primary">@nameof(_dedicatedConfig.CrossPlatform)</MudSwitch>
                                    </MudTooltip>

                                    <!-- PauseGameWhenEmpty (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.PauseGameWhenEmpty))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.PauseGameWhenEmpty" Color="Color.Primary">@nameof(_dedicatedConfig.PauseGameWhenEmpty)</MudSwitch>
                                    </MudTooltip>

                                    <!-- MessageOfTheDay (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.MessageOfTheDay))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.MessageOfTheDay)" @bind-Value="_dedicatedConfig.MessageOfTheDay" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- MessageOfTheDayUrl (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.MessageOfTheDayUrl))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.MessageOfTheDayUrl)" @bind-Value="_dedicatedConfig.MessageOfTheDayUrl" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- AutoRestartEnabled (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoRestartEnabled))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.AutoRestartEnabled" Color="Color.Primary">@nameof(_dedicatedConfig.AutoRestartEnabled)</MudSwitch>
                                    </MudTooltip>

                                    <!-- AutoRestatTimeInMin (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoRestatTimeInMin))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.AutoRestatTimeInMin)" @bind-Value="_dedicatedConfig.AutoRestatTimeInMin" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- AutoUpdateEnabled (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoUpdateEnabled))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.AutoUpdateEnabled" Color="Color.Primary">@nameof(_dedicatedConfig.AutoUpdateEnabled)</MudSwitch>
                                    </MudTooltip>

                                    <!-- AutoUpdateCheckIntervalInMin (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoUpdateCheckIntervalInMin))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.AutoUpdateCheckIntervalInMin)" @bind-Value="_dedicatedConfig.AutoUpdateCheckIntervalInMin" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- AutoUpdateRestartDelayInMin (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoUpdateRestartDelayInMin))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.AutoUpdateRestartDelayInMin)" @bind-Value="_dedicatedConfig.AutoUpdateRestartDelayInMin" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- RestartSave (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.RestartSave))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.RestartSave" Color="Color.Primary">@nameof(_dedicatedConfig.RestartSave)</MudSwitch>
                                    </MudTooltip>

                                    <!-- AutoUpdateSteamBranch (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoUpdateSteamBranch))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.AutoUpdateSteamBranch)" @bind-Value="_dedicatedConfig.AutoUpdateSteamBranch" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- AutoUpdateBranchPassword (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutoUpdateBranchPassword))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.AutoUpdateBranchPassword)" @bind-Value="_dedicatedConfig.AutoUpdateBranchPassword" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- ServerDescription (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.ServerDescription))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.ServerDescription)" @bind-Value="_dedicatedConfig.ServerDescription" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- ServerPasswordHash (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.ServerPasswordHash))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.ServerPasswordHash)" @bind-Value="_dedicatedConfig.ServerPasswordHash" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- ServerPasswordSalt (string) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.ServerPasswordSalt))">
                                        <MudTextField T="string" Label="@nameof(_dedicatedConfig.ServerPasswordSalt)" @bind-Value="_dedicatedConfig.ServerPasswordSalt" Variant="Variant.Outlined" />
                                    </MudTooltip>

                                    <!-- Plugins (List<string>) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.Plugins))">
                                        <MudTextField T="string"
                                                      Label="@nameof(_dedicatedConfig.Plugins)"
                                                      @bind-Value="PluginsText"
                                                      Variant="Variant.Outlined"
                                                      Lines="5"
                                                      FullWidth="true" />
                                    </MudTooltip>

                                    <!-- AutodetectDependencies (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.AutodetectDependencies))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.AutodetectDependencies" Color="Color.Primary">@nameof(_dedicatedConfig.AutodetectDependencies)</MudSwitch>
                                    </MudTooltip>

                                    <!-- SaveChatToLog (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.SaveChatToLog))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.SaveChatToLog" Color="Color.Primary">@nameof(_dedicatedConfig.SaveChatToLog)</MudSwitch>
                                    </MudTooltip>

                                    <!-- ChatAntiSpamEnabled (bool) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.ChatAntiSpamEnabled))">
                                        <MudSwitch T="bool" @bind-Value="_dedicatedConfig.ChatAntiSpamEnabled" Color="Color.Primary">@nameof(_dedicatedConfig.ChatAntiSpamEnabled)</MudSwitch>
                                    </MudTooltip>

                                    <!-- SameMessageTimeout (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.SameMessageTimeout))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.SameMessageTimeout)" @bind-Value="_dedicatedConfig.SameMessageTimeout" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- SpamMessagesTime (float) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.SpamMessagesTime))">
                                        <MudNumericField T="float" Label="@nameof(_dedicatedConfig.SpamMessagesTime)" @bind-Value="_dedicatedConfig.SpamMessagesTime" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- SpamMessagesTimeout (int) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.SpamMessagesTimeout))">
                                        <MudNumericField T="int" Label="@nameof(_dedicatedConfig.SpamMessagesTimeout)" @bind-Value="_dedicatedConfig.SpamMessagesTimeout" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <!-- DedicatedId (long) -->
                                    <MudTooltip Text="@GetDescription(nameof(_dedicatedConfig.DedicatedId))">
                                        <MudNumericField T="long" Label="@nameof(_dedicatedConfig.DedicatedId)" @bind-Value="_dedicatedConfig.DedicatedId" Variant="Variant.Outlined" Min="0" />
                                    </MudTooltip>

                                    <MudDivider Class="mt-2" />

                                    <!-- Update button: sends serialized model to client command DedicatedCfgSchema -->
                                    <MudStack Row Justify="Justify.FlexEnd">
                                        <MudButton Color="Color.Primary" Variant="Variant.Filled" OnClick="UpdateDedicatedConfigAsync">
                                            Update Dedicated Config
                                        </MudButton>
                                    </MudStack>
                                </MudStack>
                            }
                        </MudTabPanel>
                    </MudTabs>
                </MudPaper>
            </MudItem>
        }



    </MudGrid>

</MudStack>






@code {
    [Parameter] public string InstanceId { get; set; } = default!;


    private MudForm? _form;
    private ProfileCfg? _selectedProfile;
    private string? _originalProfileName;
    private string? _previousprofilename;

    private ConfigDedicatedSE1? _dedicatedConfig => _instance?.DedicatedConfig;
    private TorchInstance? _instance;

    // Helper properties to edit List<T> fields as multiline textarea (newline-separated)
    private string AdministratorsText
    {
        get => _dedicatedConfig?.Administrators == null ? string.Empty : string.Join(Environment.NewLine, _dedicatedConfig.Administrators);
        set
        {
            if (_dedicatedConfig == null) return;
            _dedicatedConfig.Administrators = string.IsNullOrWhiteSpace(value)
                ? new List<string>()
                : value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                       .Select(s => s.Trim())
                       .Where(s => s.Length > 0)
                       .ToList();
        }
    }

    private string BannedText
    {
        get => _dedicatedConfig?.Banned == null ? string.Empty : string.Join(Environment.NewLine, _dedicatedConfig.Banned.Select(b => b.ToString()));
        set
        {
            if (_dedicatedConfig == null) return;
            var lines = string.IsNullOrWhiteSpace(value)
                ? Array.Empty<string>()
                : value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            var list = new List<ulong>();
            foreach (var line in lines.Select(l => l.Trim()))
            {
                if (ulong.TryParse(line, out var v))
                    list.Add(v);
            }

            _dedicatedConfig.Banned = list;
        }
    }

    private string ReservedText
    {
        get => _dedicatedConfig?.Reserved == null ? string.Empty : string.Join(Environment.NewLine, _dedicatedConfig.Reserved.Select(r => r.ToString()));
        set
        {
            if (_dedicatedConfig == null) return;
            var lines = string.IsNullOrWhiteSpace(value)
                ? Array.Empty<string>()
                : value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries);

            var list = new List<ulong>();
            foreach (var line in lines.Select(l => l.Trim()))
            {
                if (ulong.TryParse(line, out var v))
                    list.Add(v);
            }

            _dedicatedConfig.Reserved = list;
        }
    }

    private string PluginsText
    {
        get => _dedicatedConfig?.Plugins == null ? string.Empty : string.Join(Environment.NewLine, _dedicatedConfig.Plugins);
        set
        {
            if (_dedicatedConfig == null) return;
            _dedicatedConfig.Plugins = string.IsNullOrWhiteSpace(value)
                ? new List<string>()
                : value.Split(new[] { '\r', '\n' }, StringSplitOptions.RemoveEmptyEntries)
                       .Select(s => s.Trim())
                       .Where(s => s.Length > 0)
                       .ToList();
        }
    }

    protected override async Task OnInitializedAsync()
    {
        _instance = InstanceManager.GetInstanceByID(InstanceId);
        InstanceManager.OnChange += OnInstanceUpdated;

        _selectedProfile = _instance?.Profiles.FirstOrDefault();
        _previousprofilename = _selectedProfile?.InstanceName;

        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        // request dedicated schema from the instance
        await InstanceManager.SendCommand(_instance, "Config/Profiles/dedicatedcfg");
    }

    private void OnInstanceUpdated(string updatedId)
    {
        if (updatedId != _instance.InstanceID)
            return;

        InvokeAsync(() =>
        {
            _instance = InstanceManager.GetInstanceByID(InstanceId);
            StateHasChanged();
        });
    }

    private async Task SelectProfile(ProfileCfg profile)
    {
        _selectedProfile = profile;
        _originalProfileName = profile.InstanceName;

        // Request the dedicated config for the selected profile from the instance
        if (_instance != null && !string.IsNullOrWhiteSpace(profile?.InstanceName) && _selectedProfile?.InstanceName != _previousprofilename)
        {
            _previousprofilename = _selectedProfile?.InstanceName;
            await InstanceManager.SendCommand(_instance, "Config/Profiles/dedicatedcfg", new { profile = profile.InstanceName });
        }

        StateHasChanged();
    }

    private async Task OnProfileSelectedAsync(ProfileCfg? profile)
    {
        if (profile != null)
            await SelectProfile(profile);
    }

    private async Task CreateProfileAsync()
    {
        if (_instance is null)
            return;

        var options = new DialogParameters
        {
            ["Label"] = "Profile Name",
            ["Value"] = string.Empty,
            ["Title"] = "Create Profile",
            ["ConfirmText"] = "Create",
            ["CancelText"] = "Cancel"
        };

        var dialogRef = await DialogService.ShowAsync<Torch2WebUI.Components.Dialogs.InputDialog>("Create Profile", options, new DialogOptions { MaxWidth = MaxWidth.Small, FullWidth = true });
        var result = await dialogRef.Result;
        if (result.Canceled || result.Data is null)
            return;

        if (result.Data is string name && !string.IsNullOrWhiteSpace(name))
        {
            await InstanceManager.SendCommand(_instance, "Config/Profiles/Create", new { name = name.Trim() });
            await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        }
    }

    // New: single confirm method that accepts an optional ProfileCfg.
    // Call without parameter to delete the selected profile, or pass a profile for item-level delete.
    private async Task ConfirmDeleteProfile(ProfileCfg? profile = null)
    {
        var target = profile ?? _selectedProfile;
        if (_instance is null || target is null)
            return;

        var dialogParams = new DialogParameters
        {
            ["Message"] = $"Delete profile '{target.InstanceName}'? This cannot be undone.",
            ["Args"] = target.InstanceName,
            ["ConfirmText"] = "Delete",
            ["CancelText"] = "Cancel",
            ["ShowCancel"] = true,
            ["ButtonIcon"] = Icons.Material.Filled.Delete
        };

        var dialogRef = await DialogService.ShowAsync<Torch2WebUI.Components.Dialogs.ConfirmDialog>($"Delete Profile '{target.InstanceName}'?", dialogParams);
        var result = await dialogRef.Result;

        if (!result.Canceled && result.Data is string confirmedName)
        {
            await InstanceManager.SendCommand(_instance, "Config/Profiles/Delete", new { name = confirmedName });
            if (_selectedProfile != null && string.Equals(_selectedProfile.InstanceName, confirmedName, StringComparison.OrdinalIgnoreCase))
            {
                _selectedProfile = null;
                _originalProfileName = null;
            }
            await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
        }
    }

    // kept for backward compatibility with previous wiring; delegates to ConfirmDeleteProfile()
    private Task DeleteSelectedProfileAsync() => ConfirmDeleteProfile();

    private async Task UpdateSelectedProfileAsync()
    {
        if (_instance is null || _selectedProfile is null)
            return;

        // Use the original name as the existing identifier (in case the user renamed the InstanceName)
        var payload = new
        {
            name = _originalProfileName ?? _selectedProfile.InstanceName,
            newname = _selectedProfile.InstanceName,
            targetworld = _selectedProfile.TargetWorld,
            description = _selectedProfile.Description,
            port = _selectedProfile.InstancePort,
            autostart = _selectedProfile.AutoStart,
            checkupdates = _selectedProfile.CheckForUpdates,
            autoupdategame = _selectedProfile.AutoUpdateGame,
            restartoncrash = _selectedProfile.RestartOnCrash,
            branch = _selectedProfile.BranchName,
            branchpwd = _selectedProfile.BranchPassword,
            logsmaxage = _selectedProfile.LogsMaxAge
        };

        await InstanceManager.SendCommand(_instance, "Config/Profiles/Update", payload);

        // refresh list
        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
    }

    // Implemented load: tells the instance to load the selected profile.
    private async Task LoadProfileAsync()
    {
        if (_instance is null || _selectedProfile is null)
            return;

        await InstanceManager.SendCommand(_instance, "Config/Profiles/Load", new { name = _selectedProfile.InstanceName });

        // refresh list / server state after request
        await InstanceManager.SendCommand(_instance, "Config/Profiles/List");
    }

    // New: send updated dedicated config DTO to client command (model must be JSON string)
    private async Task UpdateDedicatedConfigAsync()
    {
        if (_instance is null || _dedicatedConfig is null || _selectedProfile is null)
            return;

        // Serialize model to JSON string (server client's command expects --model as a JSON string)
        var modelJson = JsonSerializer.Serialize(_dedicatedConfig, new JsonSerializerOptions { PropertyNameCaseInsensitive = true });

        // Send to the client command. The client command signature expects a string 'model' parameter.
        await InstanceManager.SendCommand(_instance, "Config/Profiles/dedicatedcfg", new { model = modelJson, profile = _selectedProfile.InstanceName });

        // Optionally request the client to resend current schema after applying (refresh),
        // client implementation already posts back DedicatedSchema via WebAPI when applying.
        // But request a fresh schema to ensure UI sync:
        await InstanceManager.SendCommand(_instance, "Config/Profiles/dedicatedcfg");
    }

    public void Dispose()
    {
        InstanceManager.OnChange -= OnInstanceUpdated;
    }


    // Helper: get DescriptionAttribute string for a property
    private static string GetDescription(string propName)
    {
        var prop = typeof(ConfigDedicatedSE1).GetProperty(propName, BindingFlags.Public | BindingFlags.Instance | BindingFlags.IgnoreCase);
        var attr = prop?.GetCustomAttribute<DescriptionAttribute>();
        return attr?.Description ?? string.Empty;
    }



        
